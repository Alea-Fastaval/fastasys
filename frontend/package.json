{
  "name": "fastasys",
  "version": "0.0.0",
  "scripts": {
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "start": "ng serve --no-hmr --proxy-config proxy.conf.json",
    "start-hmr": "ng serve --proxy-config proxy.conf.json",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "test": "vitest --run --coverage",
    "test:watch": "vitest",
    "validate": "npm audit --audit-level=high",
    "format": "prettier --write \"src/**/*.{ts,js,json,css,scss,html,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,css,scss,html,md}\""
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@primeuix/themes": "^2.0.3",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.9",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.16",
    "@angular/cli": "^21.2.16",
    "@angular/compiler-cli": "^21.2.17",
    "@eslint/js": "^9.39.1",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "^21.4.0",
    "eslint": "^9.39.1",
    "jsdom": "^27.1.0",
    "prettier": "3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.27.3": true,
    "lmdb@3.5.1": true,
    "msgpackr-extract@3.0.4": true
  }
}
