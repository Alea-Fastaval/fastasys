{
  "name": "fastasys",
  "version": "0.0.0",
  "scripts": {
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "start": "ng serve --no-hmr --proxy-config proxy.conf.json",
    "start-hmr": "ng serve --proxy-config proxy.conf.json",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "test": "vitest --run --coverage",
    "test:watch": "vitest",
    "validate": "npm audit --audit-level=high",
    "format": "prettier --write \"src/**/*.{ts,js,json,css,scss,html,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,css,scss,html,md}\""
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.10",
    "@angular/compiler": "^20.3.10",
    "@angular/core": "^20.3.10",
    "@angular/forms": "^20.3.10",
    "@angular/platform-browser": "^20.3.10",
    "@angular/router": "^20.3.10",
    "@primeuix/themes": "^1.2.5",
    "primeicons": "^7.0.0",
    "primeng": "^20.3.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.9",
    "@angular/cli": "^20.3.9",
    "@angular/compiler-cli": "^20.3.10",
    "@eslint/js": "^9.39.1",
    "@vitest/coverage-v8": "^3.2.4",
    "angular-eslint": "20.5.1",
    "eslint": "^9.39.1",
    "jsdom": "^27.1.0",
    "prettier": "3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^3.2.4"
  }
}
